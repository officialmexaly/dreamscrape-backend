# Database Configuration (direct database host with your specified parameters)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require
# NextAuth Configuration
AUTH_SECRET=your_auth_secret_here_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_KEY=your_supabase_key_here

# Server Configuration
PORT=8080
GIN_MODE=debug

JWT_SECRET="your_jwt_secret_here_generate_random_string"

# CORS Configuration
FRONTEND_URL=http://localhost:3000

CSRUF_SECRET=your_csrf_secret_key_here
RESEND_API_KEY=your_resend_api_key_here

# Cache Invalidation
NEXTJS_REVALIDATION_URL=http://localhost:3000/api/revalidate

# Supabase Database Configuration (for direct database access)
# Note: Using Supabase REST API only - read operations only
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_API_URL=your_supabase_api_url_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Calendly Integration
CALENDLY_TOKEN=your_calendly_token_here

# Calendly Event Type Configuration
# Get your event type UUID from: https://api.calendly.com/event_types
# Or leave empty to use the first active event type
CALENDLY_EVENT_TYPE_URI=
