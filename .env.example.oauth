# ==========================================
# OAUTH 2.0 CONFIGURATION
# ==========================================

# Google OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Facebook OAuth 2.0
FACEBOOK_OAUTH_CLIENT_ID=your-facebook-app-id
FACEBOOK_OAUTH_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/facebook/callback

# Apple OAuth 2.0
APPLE_OAUTH_CLIENT_ID=your-apple-client-id
APPLE_OAUTH_CLIENT_SECRET=your-apple-team-id-client-secret
APPLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/apple/callback

# ==========================================
# OAUTH PROVIDER SETUP GUIDE
# ==========================================

# Google OAuth Setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Navigate to APIs & Services > Credentials
# 4. Create OAuth 2.0 client ID
# 5. Add authorized redirect URI: http://localhost:8080/api/auth/google/callback
# 6. For production: https://yourdomain.com/api/auth/google/callback

# Facebook OAuth Setup:
# 1. Go to https://developers.facebook.com/apps/
# 2. Create a new app: "Dreamscape Events"
# 3. Add "Facebook Login" product
# 4. Set OAuth redirect URI: http://localhost:8080/api/auth/facebook/callback
# 5. For production: https://yourdomain.com/api/auth/facebook/callback
# 6. Copy App ID and App Secret

# Apple OAuth Setup:
# 1. Go to https://developer.apple.com/
# 2. Navigate to Certificates, Identifiers & Profiles
# 3. Create a new App ID with "Sign in with Apple" capability
# 4. Configure Sign in with Apple:
#    - Enable email and name
#    - Return URL: http://localhost:8080/api/auth/apple/callback
#    - For production: https://yourdomain.com/api/auth/apple/callback
# 5. Generate and download your private key (team ID + key ID)
# 6. Configure Team ID and Client Secret