{
  "builds": [
    {
      "src": "main.go",
      "use": "@vercel/go",
      "config": {
        "include": [
          "config/**/*",
          "pkg/**/*",
          "backend/**/*"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/main.go"
    }
  ],
  "include": [
    "config/**/*"
  ]
}