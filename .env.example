# ==========================================
# DREAMSCAPE BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# Copy this file to .env for local development
# For production, use pro.env

# Server Configuration
PORT=8080
GIN_MODE=debug
FRONTEND_URL=http://localhost:3000

# Database Configuration (Supabase)
SUPABASE_URL=your-supabase-project-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_BUCKET=media

# Authentication Configuration
JWT_SECRET=your-jwt-secret-key-here
AUTH_SECRET=your-nextauth-secret-here

# Security Configuration
CSRF_SECRET=your-csrf-secret-here
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Calendly Integration (Optional)
CALENDLY_TOKEN=your-calendly-token-here

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key-here
FROM_EMAIL=noreply@dreamscape-events.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10

# Next.js Cache Invalidation (Optional)
NEXTJS_REVALIDATION_URL=http://localhost:3000/api/revalidate

# OAuth 2.0 Configuration (Optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/facebook/callback

APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/apple/callback