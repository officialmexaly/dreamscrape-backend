# ==========================================
# DREAMSCAPE CURATED EVENTS - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# ==========================================
# ADMIN CREDENTIALS (REQUIRED)
# ==========================================
# Admin email for authentication
ADMIN_EMAIL=admin@dreamscapeevents.com

# Admin password (MUST be at least 8 characters with uppercase, lowercase, and numbers)
ADMIN_PASSWORD=ChangeThisPassword123!

# JWT secret key for token generation (generate a strong random string)
# Use: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# CSRF secret key for CSRF protection (generate a strong random string)
# Use: openssl rand -base64 32
CSRF_SECRET=your-csrf-secret-key-change-this-in-production

# Access token lifetime (default: 15m)
ACCESS_TOKEN_DURATION=15m

# Refresh token lifetime (default: 168h = 7 days)
REFRESH_TOKEN_DURATION=168h

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
# Backend API URL
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8080

# Backend server port (default: 8080)
PORT=8080

# Gin mode: debug, release, test
GIN_MODE=debug

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose this as NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase database connection string
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Supabase storage configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here
SUPABASE_BUCKET=media
MAX_UPLOAD_SIZE_MB=10

# ==========================================
# STORAGE CONFIGURATION
# ==========================================
# S3-Compatible Storage (Zexfa or Supabase Storage)
S3_ENDPOINT=https://api.storage.zexfa.com
S3_REGION=us-east-1
S3_BUCKET=dreamscrap
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_BASE_URL=https://api.storage.zexfa.com/dreamscrap

# Public S3 configuration (exposed to client)
NEXT_PUBLIC_S3_ENDPOINT=https://api.storage.zexfa.com
NEXT_PUBLIC_S3_BUCKET=dreamscrap
NEXT_PUBLIC_S3_PUBLIC_BASE_URL=https://api.storage.zexfa.com/dreamscrap

# ==========================================
# BUSINESS CONTACT INFORMATION
# ==========================================
NEXT_PUBLIC_BUSINESS_EMAIL=info@dreamscapeevent.com
NEXT_PUBLIC_BUSINESS_PHONE=+2348169246969
NEXT_PUBLIC_BUSINESS_ADDRESS="123 Event Street, New York, NY 10001"

# WhatsApp number (with country code, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348169246969

# ==========================================
# CALENDLY INTEGRATION
# ==========================================
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/30min
CALENDLY_API_TOKEN=your-personal-access-token
CALENDLY_EVENT_TYPE_URI=https://api.calendly.com/event_types/your-event-type-uuid

# ==========================================
# GOOGLE CALENDAR INTEGRATION
# ==========================================
# Google account email for receiving consultation bookings
NEXT_PUBLIC_CALENDAR_EMAIL=your-email@gmail.com

# Google Service Account for calendar API
GOOGLE_CALENDAR_CLIENT_EMAIL="your-service-account@project-id.iam.gserviceaccount.com"
GOOGLE_CALENDAR_ID="primary"

# Google OAuth2 credentials for backend calendar integration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# STRIPE PAYMENT CONFIGURATION
# ==========================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Webhook Secret
# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==========================================
# EMAIL CONFIGURATION (RESEND)
# ==========================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Backend email configuration
FROM_EMAIL=noreply@dreamscape-events.com

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Application URL (used in emails and redirects)
# For production: NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# NEXTAUTH CONFIGURATION
# ==========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
# For production: NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ==========================================
# DATABASE CONNECTION
# ==========================================
# For Supabase, use: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Get your database password from: https://supabase.com/dashboard/project/[PROJECT]/settings/database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres?pgbouncer=true

# ==========================================
# RATE LIMITING (OPTIONAL)
# ==========================================
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Requests per hour per IP
RATE_LIMIT_PER_HOUR=1000

# For production, use Redis or Upstash for persistent, distributed rate limiting

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# Cookie domain (leave empty for localhost)
COOKIE_DOMAIN=

# Cookie secure flag (set to true in production with HTTPS)
COOKIE_SECURE=false
# Get a free Redis instance at: https://upstash.com/ or https://redis.com/
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here
